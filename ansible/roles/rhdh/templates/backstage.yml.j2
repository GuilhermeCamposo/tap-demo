apiVersion: rhdh.redhat.com/v1alpha3
kind: Backstage
metadata:
  name: developer-hub
spec:
  deployment:
    patch:
      spec:
        template:
          spec:
            volumes:
              - $patch: replace
                name: dynamic-plugins-root
                persistentVolumeClaim:
                  claimName: dynamic-plugins-root
  application:
    dynamicPluginsConfigMapName: dynamic-plugins-rhdh
    appConfig:
      mountPath: /opt/app-root/src      
      configMaps:
         - name: {{ rhdh_cm_name }}
    extraFiles:
      mountPath: /opt/app-root/src     
      configMaps:
         - name: rbac-policies
    extraEnvs:
      secrets:
         - name: {{ rhdh_secret_name }}
    replicas: 1
    route:
      enabled: true
  database:
    enableLocalDb: true